<Project>
  <PropertyGroup>
    <WebPublishMethod>ZipDeploy</WebPublishMethod>
    <PublishProvider>AzureWebSite</PublishProvider>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <SiteUrlToLaunchAfterPublish>http://profet-prueba.azurewebsites.net</SiteUrlToLaunchAfterPublish>
    <LaunchSiteAfterPublish>true</LaunchSiteAfterPublish>
    <ProjectGuid>0d11fdeb-a5cc-4fbe-ae64-80804b993793</ProjectGuid>
    <PublishUrl>https://profet-prueba.scm.azurewebsites.net/</PublishUrl>
    <UserName>$profet-prueba</UserName>
    <_SavePWD>true</_SavePWD>
  </PropertyGroup>
</Project>