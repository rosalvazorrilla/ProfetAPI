    {
      "name": "🔗 Asignación Usuario → Cuenta",
      "item": [
        {
          "name": "POST Asignar usuario a cuenta",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/setup/accounts/{{accountId}}/users?token={{token}}",
              "host": ["{{baseUrl}}"],
              "path": ["api","setup","accounts","{{accountId}}","users"],
              "query": [{ "key": "token", "value": "{{token}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"roleInAccount\": \"Admin\"\n}"
            }
          },
          "description": "Vincula un usuario del pool del wizard a una cuenta específica con un rol. RoleInAccount: 'Admin' | 'SalesRep' | 'Viewer'. Si el usuario ya estaba asignado con otro rol, lo reemplaza."
        },
        {
          "name": "DELETE Desasignar usuario de cuenta",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/setup/accounts/{{accountId}}/users/{{userId}}?token={{token}}",
              "host": ["{{baseUrl}}"],
              "path": ["api","setup","accounts","{{accountId}}","users","{{userId}}"],
              "query": [{ "key": "token", "value": "{{token}}" }]
            }
          }
        }
      ]
    },

